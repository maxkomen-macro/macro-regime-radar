# Copy this file to .streamlit/secrets.toml and fill in your API keys.
# Do NOT commit secrets.toml to git — it is listed in .gitignore.

# ── Required ────────────────────────────────────────────────────────────
FRED_API_KEY = "your_fred_api_key_here"

# ── Legacy / optional ──────────────────────────────────────────────────
# Polygon was the original market data source. The active pipeline uses
# yfinance (no key required). Keep this only if you want to fall back to
# the Polygon code path in src/market_data/polygon.py.
POLYGON_API_KEY = "your_polygon_api_key_here"

# ── Optional Phase-11 keys (news + AI interpretation) ───────────────────
# Without these, the news, regime interpretation, and research-citation
# pipelines silently produce no output. Uncomment and fill in to enable.
# FINNHUB_API_KEY    = "your_finnhub_api_key_here"
# NEWS_API_KEY       = "your_newsapi_key_here"
# ANTHROPIC_API_KEY  = "your_anthropic_api_key_here"
# PERPLEXITY_API_KEY = "your_perplexity_api_key_here"
